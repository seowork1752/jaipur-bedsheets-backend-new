# ═══════════════════════════════════════════════════════════════════════════════
# JAIPUR BEDSHEETS - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000
API_URL=https://api.jaipur-bedsheets.com
FRONTEND_URL=https://jaipur-bedsheets.com

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# MongoDB Atlas (Recommended)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/jaipur-bedsheets?retryWrites=true&w=majority

# Local MongoDB (Development)
# MONGODB_URI=mongodb://localhost:27017/jaipur-bedsheets

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY & AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_for_security_12345
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_characters_long_12345
JWT_REFRESH_EXPIRE=30d

# Password Reset
RESET_TOKEN_EXPIRE=15m

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENT GATEWAY (RAZORPAY)
# ═══════════════════════════════════════════════════════════════════════════════

# Get from https://dashboard.razorpay.com/settings/api-keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=rzp_test_secret_XXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXX

# Razorpay Test Credentials (for development)
# Card: 4111 1111 1111 1111 | 12/25 | 123
# UPI: success@razorpay

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL SERVICE (SMTP)
# ═══════════════════════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SENDER_EMAIL=noreply@jaipur-bedsheets.com
SENDER_NAME=Jaipur Bedsheets

# Alternative: SendGrid
# SENDGRID_API_KEY=SG.XXXXXXXXXXXXX

# Alternative: AWS SES
# AWS_REGION=ap-south-1
# AWS_SES_ACCESS_KEY_ID=XXXXXXXXXXXXX
# AWS_SES_SECRET_ACCESS_KEY=XXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUD STORAGE (CLOUDINARY)
# ═══════════════════════════════════════════════════════════════════════════════

# Get from https://cloudinary.com/console/settings/api-keys
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Alternative: AWS S3
# AWS_S3_ACCESS_KEY_ID=XXXXXXXXXXXXX
# AWS_S3_SECRET_ACCESS_KEY=XXXXXXXXXXXXX
# AWS_S3_BUCKET=jaipur-bedsheets
# AWS_S3_REGION=ap-south-1

# ═══════════════════════════════════════════════════════════════════════════════
# SHIPPING & LOGISTICS
# ═══════════════════════════════════════════════════════════════════════════════

SHIPROCKET_API_KEY=your-shiprocket-api-key
SHIPROCKET_EMAIL=your-email@shiprocket.in
SHIPROCKET_PASSWORD=your-shiprocket-password

# ═══════════════════════════════════════════════════════════════════════════════
# SMS SERVICE (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════════

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Alternative: AWS SNS
# AWS_SNS_REGION=ap-south-1

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE & SESSION (REDIS)
# ═══════════════════════════════════════════════════════════════════════════════

# Local Development
REDIS_URL=redis://localhost:6379

# Production (e.g., Redis Cloud)
# REDIS_URL=redis://:password@hostname:port

# ═══════════════════════════════════════════════════════════════════════════════
# BUSINESS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Tax Configuration
GST_RATE=18

# Shipping Configuration
FREE_SHIPPING_THRESHOLD=500
SHIPPING_COST=100

# Return Policy
RETURN_WINDOW_DAYS=30

# Discount Configuration
MAX_DISCOUNT_PERCENTAGE=50

# ═══════════════════════════════════════════════════════════════════════════════
# ADMIN SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

ADMIN_EMAIL=admin@jaipur-bedsheets.com
ADMIN_PASSWORD=Admin@123456

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

ENABLE_PAYMENT=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_AFFILIATE_PROGRAM=false
ENABLE_LOYALTY_POINTS=true
ENABLE_REVIEW_MODERATION=true

# ═══════════════════════════════════════════════════════════════════════════════
# API RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

CORS_ORIGINS=https://jaipur-bedsheets.com,https://www.jaipur-bedsheets.com,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

LOG_LEVEL=info
LOG_FORMAT=combined

# Sentry Error Tracking (Optional)
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Google Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY HEADERS
# ═══════════════════════════════════════════════════════════════════════════════

FORCE_HTTPS=true
CSP_ENABLED=true
HELMET_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS (DISABLE IN PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════════════

DEBUG=false
ALLOW_SEED_DATA=false
ENABLE_API_DOCS=true

# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ═══════════════════════════════════════════════════════════════════════════════

# 1. NEVER commit this file to version control
# 2. Use strong, unique values for all secrets
# 3. Rotate secrets regularly in production
# 4. Use environment-specific values
# 5. Use AWS Secrets Manager or similar in production
# 6. Enable audit logging
# 7. Restrict .env file permissions (chmod 600)
# 8. Use separate .env files for dev, staging, production

# ═══════════════════════════════════════════════════════════════════════════════
# GETTING STARTED
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in all required values (marked with *)
# 3. Test database connections
# 4. Test payment gateway
# 5. Test email service
# 6. Run: npm run dev
# 7. Check http://localhost:5000/api/health

# ═══════════════════════════════════════════════════════════════════════════════
